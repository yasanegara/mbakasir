generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SuperAdmin {
  id           String                  @id @default(cuid())
  name         String
  email        String                  @unique
  passwordHash String
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  agentLinks   AgentRegistrationLink[]
  tokenMints   TokenLedger[]           @relation("MintedBy")

  @@map("super_admins")
}

model Agent {
  id                         String                      @id @default(cuid())
  name                       String
  email                      String                      @unique
  phone                      String?
  passwordHash               String
  tokenBalance               Int                         @default(0)
  totalMinted                Int                         @default(0)
  totalUsed                  Int                         @default(0)
  isActive                   Boolean                     @default(true)
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  tokenResalePrice           Decimal                     @default(0) @db.Decimal(15, 2)
  bankDetails                String?
  whatsappNumber             String?
  telegramChatId             String?
  registrationLinkId         String?
  nik                        String?
  qrisUrl                    String?
  notificationPrefs          Json?                       @default("{\"notifyNewStoreRegistration\": true, \"notifyTokenPurchase\": true}")
  agentTokenPurchaseRequests AgentTokenPurchaseRequest[]
  vouchers                   AgentVoucher[]
  registrationLink           AgentRegistrationLink?      @relation("AgentRegisteredVia", fields: [registrationLinkId], references: [id])
  storeRegistrationLinks     StoreRegistrationLink[]
  tenants                    Tenant[]
  tokenLedger                TokenLedger[]
  purchaseRequests           TokenPurchaseRequest[]

  @@map("agents")
}

model Tenant {
  id                 String                 @id @default(cuid())
  agentId            String
  name               String
  businessType       String?
  address            String?
  phone              String?
  logoUrl            String?
  status             TenantStatus           @default(LOCKED)
  premiumUntil       DateTime?
  tokenBalance       Int                    @default(0)
  tokenUsed          Int                    @default(0)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  registrationLinkId String?
  nik                String?
  posTerminals       PosTerminal[]
  products           Product[]
  rawMaterials       RawMaterial[]
  sales              Sale[]
  shifts             Shift[]
  agent              Agent                  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  registrationLink   StoreRegistrationLink? @relation("RegisteredVia", fields: [registrationLinkId], references: [id])
  tokenLedger        TokenLedger[]
  purchaseRequests   TokenPurchaseRequest[]
  users              User[]
  storefront         StorefrontConfig?
  onlineOrders       OnlineOrder[]
  modules            TenantModule[]

  @@map("tenants")
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  email        String
  phone        String?
  passwordHash String
  role         Role     @default(CASHIER)
  pin          String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sales        Sale[]
  shifts       Shift[]
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@map("users")
}

model Product {
  id          String              @id @default(cuid())
  tenantId    String
  sku         String?
  name        String
  category    String?
  price       Decimal             @db.Decimal(15, 2)
  costPrice   Decimal             @default(0) @db.Decimal(15, 2)
  stock       Decimal             @default(0) @db.Decimal(15, 3)
  unit        String              @default("pcs")
  imageUrl    String?
  isActive    Boolean             @default(true)
  hasBoM      Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  localId     String?             @unique
  syncStatus  SyncStatus          @default(SYNCED)
  showInPos   Boolean             @default(true)
  bomItems    BillOfMaterial[]
  assignments ProductAssignment[]
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  saleItems   SaleItem[]
  orderItems  OnlineOrderItem[]

  @@unique([tenantId, sku])
  @@map("products")
}

model ProductAssignment {
  id         String      @id @default(cuid())
  productId  String
  terminalId String
  stock      Decimal     @default(0) @db.Decimal(15, 3)
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  terminal   PosTerminal @relation(fields: [terminalId], references: [id], onDelete: Cascade)

  @@unique([productId, terminalId])
  @@map("product_assignments")
}

model RawMaterial {
  id          String           @id @default(cuid())
  tenantId    String
  name        String
  unit        String           @default("gr")
  stock       Decimal          @default(0) @db.Decimal(15, 3)
  costPerUnit Decimal          @default(0) @db.Decimal(15, 4)
  minStock    Decimal          @default(0) @db.Decimal(15, 3)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  localId     String?          @unique
  syncStatus  SyncStatus       @default(SYNCED)
  bomItems    BillOfMaterial[]
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("raw_materials")
}

model BillOfMaterial {
  id            String      @id @default(cuid())
  productId     String
  rawMaterialId String
  quantity      Decimal     @db.Decimal(15, 4)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)

  @@unique([productId, rawMaterialId])
  @@map("bill_of_materials")
}

model Shift {
  id          String     @id @default(cuid())
  tenantId    String
  userId      String
  openingCash Decimal    @db.Decimal(15, 2)
  closingCash Decimal?   @db.Decimal(15, 2)
  totalSales  Decimal    @default(0) @db.Decimal(15, 2)
  totalVoid   Decimal    @default(0) @db.Decimal(15, 2)
  startedAt   DateTime   @default(now())
  closedAt    DateTime?
  notes       String?
  localId     String?    @unique
  syncStatus  SyncStatus @default(SYNCED)
  sales       Sale[]
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("shifts")
}

model Sale {
  id             String        @id @default(cuid())
  tenantId       String
  userId         String
  shiftId        String?
  invoiceNo      String
  status         SaleStatus    @default(COMPLETED)
  paymentMethod  PaymentMethod @default(CASH)
  subtotal       Decimal       @db.Decimal(15, 2)
  discountAmount Decimal       @default(0) @db.Decimal(15, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(15, 2)
  totalAmount    Decimal       @db.Decimal(15, 2)
  paidAmount     Decimal       @db.Decimal(15, 2)
  changeAmount   Decimal       @default(0) @db.Decimal(15, 2)
  notes          String?
  voidReason     String?
  voidedAt       DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  localId        String?       @unique
  syncStatus     SyncStatus    @default(PENDING)
  terminalId     String?
  items          SaleItem[]
  shift          Shift?        @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  terminal       PosTerminal?  @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, invoiceNo])
  @@map("sales")
}

model SaleItem {
  id          String  @id @default(cuid())
  saleId      String
  productId   String
  productName String
  price       Decimal @db.Decimal(15, 2)
  costPrice   Decimal @default(0) @db.Decimal(15, 2)
  quantity    Decimal @db.Decimal(15, 3)
  discount    Decimal @default(0) @db.Decimal(15, 2)
  subtotal    Decimal @db.Decimal(15, 2)
  localId     String?
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  sale        Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("sale_items")
}

model TokenLedger {
  id                  String          @id @default(cuid())
  agentId             String
  tenantId            String?
  superAdminId        String?
  type                TokenLedgerType
  amount              Int
  balanceBefore       Int
  balanceAfter        Int
  description         String
  durationMonths      Int?
  prevPremiumUntil    DateTime?
  newPremiumUntil     DateTime?
  createdAt           DateTime        @default(now())
  conversionLabel     String?
  conversionQuantity  Int?
  conversionTargetKey String?
  conversionUnit      String?
  agent               Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  superAdmin          SuperAdmin?     @relation("MintedBy", fields: [superAdminId], references: [id])
  tenant              Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("token_ledger")
}

model AgentRegistrationLink {
  id           String     @id @default(cuid())
  superAdminId String
  token        String     @unique
  isActive     Boolean    @default(true)
  useCount     Int        @default(0)
  lastUsedAt   DateTime?
  label        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id])
  agents       Agent[]    @relation("AgentRegisteredVia")

  @@map("agent_registration_links")
}

model StoreRegistrationLink {
  id              String    @id @default(cuid())
  agentId         String
  token           String    @unique
  isActive        Boolean   @default(true)
  useCount        Int       @default(0)
  lastUsedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  clickCount      Int       @default(0)
  defaultLinkType String    @default("DIRECT")
  lastClickedAt   DateTime?
  pixelUrl        String?
  agent           Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tenants         Tenant[]  @relation("RegisteredVia")

  @@map("store_registration_links")
}

model AgentVoucher {
  id            String   @id @default(cuid())
  agentId       String
  code          String
  discountValue Decimal  @default(0) @db.Decimal(15, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  agent         Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, code])
  @@map("agent_vouchers")
}

model PosTerminal {
  id            String              @id @default(cuid())
  tenantId      String
  name          String
  code          String
  isDefault     Boolean             @default(false)
  isActive      Boolean             @default(true)
  tokenCost     Int                 @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  targetRevenue Decimal             @default(0) @db.Decimal(15, 2)
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments   ProductAssignment[]
  sales         Sale[]

  @@unique([tenantId, code])
  @@map("pos_terminals")
}

model TokenPurchaseRequest {
  id          String   @id @default(cuid())
  agentId     String
  tenantId    String
  amount      Int
  totalPrice  Decimal  @db.Decimal(15, 2)
  voucherCode String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("token_purchase_requests")
}

model TokenConfig {
  id            String            @id @default("default")
  tokenName     String            @default("SuperToken")
  tokenSymbol   String            @default("T.")
  pricePerToken Decimal           @default(6250) @db.Decimal(15, 2)
  currencyCode  String            @default("IDR")
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  hppRatio      Int               @default(40)
  conversions   TokenConversion[]

  @@map("token_config")
}

model TokenConversion {
  id             String      @id @default(cuid())
  configId       String
  targetKey      String
  targetLabel    String
  moduleKey      String?
  tokenCost      Int         @default(1)
  rewardQuantity Int         @default(1)
  rewardUnit     String
  description    String?
  isActive       Boolean     @default(true)
  sortOrder      Int         @default(0)
  longDescription String?     // Deskripsi panjang untuk marketplace
  icon           String?     // Emoji atau nama icon
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  config         TokenConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, targetKey])
  @@map("token_conversions")
}

model TenantModule {
  id           String   @id @default(cuid())
  tenantId     String
  moduleKey    String   // LICENSE, STOREFRONT, CRM, WA_NOTIF, etc
  activeUntil  DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleKey])
  @@map("tenant_modules")
}

model BrandConfig {
  id              String   @id @default("default")
  appName         String   @default("MbaKasir Intelligence Pro")
  tagline         String?
  metaDescription String?
  logoUrl         String?
  faviconUrl      String?
  primaryColor    String?  @default("#1e40af")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  supportMessage  String?
  supportPhone    String?
  geminiApiKey    String?
  aiKnowledgeBase String?
  bankDetails     String?
  telegramBotToken String?
  footerPoweredByText String?  @default("Powered by MbaKasir Intelligence")
  showFooterPoweredBy Boolean  @default(true)

  @@map("brand_config")
}

model AgentPackage {
  id          String   @id @default(cuid())
  name        String
  tokenAmount Int
  price       Decimal  @db.Decimal(15, 2)
  isActive    Boolean  @default(true)
  description String?
  qrisUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("agent_packages")
}

model AgentTokenPurchaseRequest {
  id          String                          @id @default(cuid())
  agentId     String
  packageName String
  tokenAmount Int
  totalPrice  Decimal                         @db.Decimal(15, 2)
  status      AgentTokenPurchaseRequestStatus @default(PENDING)
  paymentRef  String?                         @unique // Referensi dari Tripay
  paymentMethod String?                       // Misal: QRIS, VA, dll
  createdAt   DateTime                        @default(now())
  updatedAt   DateTime                        @updatedAt
  agent       Agent                           @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_token_purchase_requests")
}

model LearnDocument {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  content         String
  excerpt         String?
  emoji           String?   @default("📄")
  targetRole      String    @default("AGENT")
  isPublished     Boolean   @default(false)
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  isPublic        Boolean   @default(false)
  version         Int       @default(1)
  publicCtaTarget String    @default("STORE")
  category        String    @default("Umum")
  seoKeywords     String?
  lastViewedAt    DateTime?
  viewCount       Int       @default(0)
  bounceCount     Int       @default(0)
  totalDuration   Int       @default(0)
  avgScrollDepth  Int       @default(0)
  finishCount     Int       @default(0)

  @@map("learn_documents")
}

model Announcement {
  id         String    @id @default(cuid())
  title      String
  content    String
  type       String    @default("info")
  targetRole String    @default("ALL")
  isActive   Boolean   @default(true)
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("announcements")
}

enum Role {
  SUPERADMIN
  AGENT
  TENANT
  CASHIER
}

enum TenantStatus {
  ACTIVE
  LOCKED
  SUSPENDED
  DORMANT
}

enum TokenLedgerType {
  MINT
  ACTIVATE
  ADJUST
  POS_ADD
}

enum SaleStatus {
  PENDING
  COMPLETED
  VOIDED
}

enum PaymentMethod {
  CASH
  TRANSFER
  QRIS
  CREDIT
}

enum SyncStatus {
  PENDING
  SYNCED
  CONFLICT
}

enum AgentTokenPurchaseRequestStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model StorefrontConfig {
  id                String        @id @default(cuid())
  tenantId          String        @unique
  slug              String        @unique
  customDomain      String?       @unique
  isActive          Boolean       @default(false)
  themeColor        String?       @default("#6366f1")
  description       String?
  bannerUrl         String?
  bankName          String?
  bankAccountNo     String?
  bankAccountName   String?
  allowShipping     Boolean       @default(true)
  shippingCost      Decimal       @default(0) @db.Decimal(15, 2)
  activeUntil       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders            OnlineOrder[]

  @@map("storefront_configs")
}

model OnlineOrder {
  id               String            @id @default(cuid())
  tenantId         String
  storefrontId     String
  customerName     String
  customerPhone    String
  customerAddress  String
  notes            String?
  shippingCost     Decimal           @default(0) @db.Decimal(15, 2)
  subtotal         Decimal           @db.Decimal(15, 2)
  totalAmount      Decimal           @db.Decimal(15, 2)
  status           OnlineOrderStatus @default(PENDING)
  trackingNumber   String?
  paymentProofUrl  String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  items            OnlineOrderItem[]
  storefront       StorefrontConfig  @relation(fields: [storefrontId], references: [id], onDelete: Cascade)
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("online_orders")
}

model OnlineOrderItem {
  id          String      @id @default(cuid())
  orderId     String
  productId   String?
  productName String
  price       Decimal     @db.Decimal(15, 2)
  quantity    Int
  subtotal    Decimal     @db.Decimal(15, 2)
  order       OnlineOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("online_order_items")
}

enum OnlineOrderStatus {
  PENDING
  CONFIRMED
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
